//--------------------------------------------------------
// Title: EE310 Assignment 4 – Version 2 (Decimal Conversion Added)
//--------------------------------------------------------
// Purpose: Adds decimal conversion using repeated subtraction.
// Dependencies: MyConfigFile.inc, xc.inc
// Compiler: MPLAB X IDE v6.30, XC8 pic-as v3.10 (Simulator)
// Author: Carlos Gonzalez
// OUTPUTS: PORTD.1, PORTD.2 and decimal digits in registers
// INPUTS: TEST_REFTEMP and TEST_MEASTEMP constants
// Versions:
//     V1.0: 03/05/2026 – Comparison logic
//     V2.0: 03/08/2026 – Added decimal conversion
//--------------------------------------------------------

#include "MyConfigFile.inc"
#include <xc.inc>

TEST_REFTEMP    EQU 44
TEST_MEASTEMP   EQU 30

refTemp       EQU 0x20
measuredTemp  EQU 0x21
contReg       EQU 0x22

refOnes       EQU 0x60
refTens       EQU 0x61
refHund       EQU 0x62

measOnes      EQU 0x70
measTens      EQU 0x71
measHund      EQU 0x72

tempVal       EQU 0x23
hundDigit     EQU 0x24
tenDigit      EQU 0x25

PSECT resetVec,class=CODE,reloc=2
ORG 0x0000
    GOTO main

PSECT code,class=CODE,reloc=2
ORG 0x0020

main:
    MOVLW TEST_REFTEMP
    MOVWF refTemp,0

    MOVLW TEST_MEASTEMP
    MOVWF measuredTemp,0

    CLRF ANSELD,0
    CLRF TRISD,0
    CLRF LATD,0

    MOVF refTemp,0,0
    MOVWF tempVal,0
    CALL convertToDigits
    MOVFF hundDigit,refHund
    MOVFF tenDigit,refTens
    MOVFF tempVal,refOnes

    SLEEP
    END

convertToDigits:
    CLRF hundDigit,0
    CLRF tenDigit,0

hundLoop:
    MOVLW 100
    SUBWF tempVal,0,0
    BTFSS STATUS,0
    GOTO tensLoop
    MOVLW 100
    SUBWF tempVal,1,0
    INCF hundDigit,1,0
    GOTO hundLoop

tensLoop:
    MOVLW 10
    SUBWF tempVal,0,0
    BTFSS STATUS,0
    RETURN
    MOVLW 10
    SUBWF tempVal,1,0
    INCF tenDigit,1,0
    GOTO tensLoop
